local function CrearBoton(nombre, posicion, callbackFunction)
	local Button = Instance.new("TextButton")
	Button.Name = nombre:gsub("[^%w]", "") -- Limpia el nombre para usarlo como identificador único
	Button.Size = UDim2.new(1, 0, 0, 40)
	Button.Position = UDim2.new(0, 0, 0, posicion)
	Button.Text = nombre
	Button.TextColor3 = Color3.new(1, 1, 1)
	Button.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
	Button.Font = Enum.Font.Gotham
	Button.TextScaled = true
	Button.Parent = Menu

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, 8) -- Bordes más suaves
	c.Parent = Button

    -- Conexión de evento (usamos el callback pasado al crear el botón)
    Button.MouseButton1Click:Connect(function()
        if callbackFunction then
            callbackFunction()
        end
    end)
	return Button
end


