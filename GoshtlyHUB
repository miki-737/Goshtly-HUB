-- 4. SELECCIÓN DE HERRAMIENTAS (Tools)
local currentTool = nil -- Variable para rastrear qué herramienta está equipada

local function EquiparHerramienta(toolName, slotIndex)
    if toolName and toolName:match("CombatKnife|Pistol") then
        -- Lógica aquí: Clonar la tool y asignarla al personaje del jugador.
        MostrarMensaje("✅ Herramienta '" .. toolName .. "' equipada con éxito en el Slot " .. slotIndex)
    else
        MostrarMensaje("❌ Error al equipar herramienta.")
    end
end

ToolsSectionHeader.MouseButton1Click:Connect(function()
     MostrarMensaje("🔪 Sistema de selección activado:\nPor favor, usa los botones debajo para seleccionar y equipar la tool deseada (CombatKnife o Pistol).")
end)

ToolSelectSlot1.MouseButton1Click:Connect(function()
    -- Aquí se asumiría que ToolSelectSlot1 está configurado para 'CombatKnife'
    EquiparHerramienta("CombatKnife", 1)
end)

ToolSelectSlot2.MouseButton1Click:Connect(function()
    -- Aquí se asumiría que ToolSelectSlot2 está configurado para 'Pistol'
    EquiparHerramienta("Pistol", 2)
end)


-- ***************************************************
-- ANIMACIÓN DE ENTRADA (Tweening)
-- ***************************************************

Main.Size = UDim2.new(0, 0, 0, 0) -- Empieza invisible en tamaño

local initialPos = Main.Position
local targetSize = UDim2.new(0, 500, 0, 380) -- Usamos el nuevo tamaño
-- Mantenemos la posición de inicio para un efecto suave al crecer.
local targetPos = UDim2.new(initialPos.ScaleX, initialPos.OffsetX, initialPos.ScaleY, initialPos.OffsetY)

TweenService:Create(
	Main,
	TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), -- Efecto de rebote (más dramático)
	{
		Size = targetSize,
        Position = targetPos 
	}
):Play()
