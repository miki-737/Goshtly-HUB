-- --- FUNCIÓN DE ESTADO (Actualiza el panel de texto con un título y mensaje)
local function UpdateDisplay(title, message)
    InfoDisplay.Text = title .. "\n\n" .. message
end

-- Función de Noclip: Toggles la propiedad CanCollide del personaje.
local noclipEnabled = false
local function ToggleNoclip()
    if not player.Character then return end
    local humanoidRootPart = player.Character:FindFirstChild("HumanoidRootPart")

    noclipEnabled = not noclipEnabled
    if noclipEnabled then
        -- Esto requiere que la física lo permita en el cliente, pero es un buen punto de partida.
        humanoidRootPart.CanCollide = false 
        UpdateDisplay("💨 Noclip", "¡Activado! Ahora puedes atravesar paredes.")
    else
        humanoidRootPart.CanCollide = true
        UpdateDisplay("💨 Noclip", "Desactivado.")
    end
end

-- Función de Herramienta: Equipar la herramienta deseada.
local function SelectTool(toolName)
    local toolsFolder = workspace:FindFirstChild("Tools") -- Asumiendo que las herramientas están en Workspace/Tools
    if not toolsFolder then 
        print("[ERROR] Carpeta 'Tools' no encontrada en el Workspace.")
        UpdateDisplay("🛠️ Herramientas", "Error: Asegúrate de que la carpeta 'Tools' exista y contenga los objetos Tool.")
        return 
    end

    local tool = toolsFolder:FindFirstChild(toolName)
    if tool and tool:IsA("Tool") then
        -- Intenta equipar el objeto directamente al personaje
        tool:SetAttribute("Equipped", true) -- Truco para forzar la detección de herramientas
        player.Character:FindFirstChild("Humanoid"):EquipTool(tool)
        UpdateDisplay("🔪 Herramienta Seleccionada", "Has equipado el '" .. toolName .. "' con éxito.")
    else
        UpdateDisplay("🛠️ Herramientas", "Error: No se encontró la herramienta '" .. toolName .. "'.")
    end
end

