-- BOTÓN PARA TODAS LAS HERRAMIENTAS
ToolsTab:CreateButton({
    Name = "🎒 Ver Todas las Tools",
    Callback = function()
        local ToolsFolder = workspace:FindFirstChild("Tools")
        local Backpack = Player:WaitForChild("Backpack")
        
        local foundTools = {}
        
        -- Buscar en Tools
        if ToolsFolder then
            for _, tool in pairs(ToolsFolder:GetChildren()) do
                if tool:IsA("Tool") then
                    table.insert(foundTools, tool.Name)
                end
            end
        end
        
        -- Buscar en Backpack
        for _, tool in pairs(Backpack:GetChildren()) do
            if tool:IsA("Tool") and not table.find(foundTools, tool.Name) then
                table.insert(foundTools, tool.Name)
            end
        end
        
        if #foundTools > 0 then
            local toolList = table.concat(foundTools, ", ")
            Rayfield:Notify({
                Title = "Tools Encontradas",
                Content = "Tienes: " .. toolList,
                Duration = 5
            })
        else
            Rayfield:Notify({
                Title = "Sin Tools",
                Content = "No se encontraron herramientas.",
                Duration = 3
            })
        end
    end,
})

