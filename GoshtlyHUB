--- Crea un botón con estilo y lo añade al menú lateral.
local function CrearBoton(nombre, posicionY)
	local Button = Instance.new("TextButton")

	Button.Size = UDim2.new(1, 0, 0, 45) -- Botones más grandes para mejor estética
	Button.Position = UDim2.new(0, 0, 0, posicionY)
	Button.Text = nombre
	Button.TextColor3 = Color3.new(1, 1, 1)
	Button.BackgroundColor3 = MAIN_COLOR
	Button.Font = Enum.Font.Gotham
	Button.TextScaled = false -- Mejor para nombres de función largos
	Button.Parent = Menu

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, 8)
	c.Parent = Button

	return Button
end


