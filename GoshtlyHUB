local VisualEffects = {
    -- Efecto Rainbow/Glow animado
    StartRainbow = function(uiElement, speed)
        if GhostlyHub.RainbowConnection then
            GhostlyHub.RainbowConnection:Disconnect()
        end
        
        local hue = 0
        GhostlyHub.RainbowConnection = RunService.RenderStepped:Connect(function(deltaTime)
            hue = (hue + deltaTime * (speed or 0.5)) % 1
            local color = Color3.fromHSV(hue, 0.8, 1)
            if uiElement and uiElement.Parent then
                pcall(function()
                    uiElement.BorderColor3 = color
                end)
            else
                if GhostlyHub.RainbowConnection then
                    GhostlyHub.RainbowConnection:Disconnect()
                end
            end
        end)
    end,
    
    -- Efecto de pulso/brillo
    StartPulse = function(uiElement, minTransparency, maxTransparency, speed)
        local increasing = true
        local current = minTransparency or 0.3
        
        GhostlyHub.PulseConnection = RunService.Heartbeat:Connect(function(deltaTime)
            if not uiElement or not uiElement.Parent then
                if GhostlyHub.PulseConnection then
                    GhostlyHub.PulseConnection:Disconnect()
                end
                return
            end
            
            local change = deltaTime * (speed or 1)
            if increasing then
                current = current + change
                if current >= (maxTransparency or 0.7) then
                    increasing = false
                end
            else
                current = current - change
                if current <= (minTransparency or 0.3) then
                    increasing = true
                end
            end
            
            pcall(function()
                if uiElement:IsA("UIStroke") then
                    uiElement.Transparency = current
                elseif uiElement:IsA("ImageLabel") then
                    uiElement.ImageTransparency = current
                end
            end)
        end)
    end,
    
    -- Efecto de partículas alrededor del cursor
    CursorParticles = function()
        local mouse = LocalPlayer:GetMouse()
        local lastPos = Vector2.new(mouse.X, mouse.Y)
        
        RunService.RenderStepped:Connect(function()
            local currentPos = Vector2.new(mouse.X, mouse.Y)
            if (currentPos - lastPos).Magnitude > 10 then
                local particle = Instance.new("Frame")
                particle.Size = UDim2.new(0, 6, 0, 6)
                particle.Position = UDim2.new(0, mouse.X - 3, 0, mouse.Y - 3)
                particle.BackgroundColor3 = CONFIG.COLORS.ACCENT
                particle.BorderSizePixel = 0
                particle.Parent = GhostlyHub.GUI
                
                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(1, 0)
                corner.Parent = particle
                
                Tween(particle, {
                    Size = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1
                }, 0.5):Play()
                
                game:GetService("Debris"):AddItem(particle, 0.5)
                lastPos = currentPos
            end
        end)
    end
}

