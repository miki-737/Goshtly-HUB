local MainTab = Window:CreateTab("🏠 Principal", 4483362458)

MainTab:CreateSection("Movimiento")

-- NOCLIP MEJORADO
local NoclipToggle = MainTab:CreateToggle({
    Name = "👻 Noclip (Atravesar Todo)",
    CurrentValue = false,
    Flag = "Noclip_Ghostly",
    Callback = function(Value)
        NoclipEnabled = Value
        
        if NoclipEnabled then
            Rayfield:Notify({
                Title = "Noclip Activado",
                Content = "Puedes atravesar paredes, puertas y objetos.",
                Duration = 3,
                Image = 4483362458,
            })
            
            -- Crear conexión de noclip
            NoclipConnection = RunService.Stepped:Connect(function()
                if not NoclipEnabled then return end
                if Player.Character then
                    for _, part in pairs(Player.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        else
            Rayfield:Notify({
                Title = "Noclip Desactivado",
                Content = "Colisión restaurada.",
                Duration = 2,
            })
            
            if NoclipConnection then
                NoclipConnection:Disconnect()
                NoclipConnection = nil
            end
            
            -- Restaurar colisión
            if Player.Character then
                for _, part in pairs(Player.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.CanCollide = true
                    end
                end
            end
        end
    end,
})

MainTab:CreateSection("Venta de Minerales")

-- BOTÓN VENDER AHORA
MainTab:CreateButton({
    Name = "💰 Vender Minerales (Manual)",
    Callback = function()
        local success, err = pcall(function()
            local MineralBuyer = Workspace:FindFirstChild("Mineral Buyer")
            
            if not MineralBuyer then
                Rayfield:Notify({
                    Title = "Error",
                    Content = "No se encontró 'Mineral Buyer' en el mapa.",
                    Duration = 3,
                    Image = 4483362458,
                })
                return
            end
            
            if not Player.Character or not HRP then
                Rayfield:Notify({
                    Title = "Error",
                    Content = "Personaje no cargado.",
                    Duration = 3,
                })
                return
            end
            
            -- Guardar posición original
            local originalCFrame = HRP.CFrame
            
            -- Buscar parte del buyer
            local buyerPart = MineralBuyer:FindFirstChild("HumanoidRootPart") or 
                             MineralBuyer:FindFirstChild("Head") or 
                             MineralBuyer:FindFirstChildWhichIsA("BasePart")
            
            if buyerPart then
                -- Teletransportar
                HRP.CFrame = buyerPart.CFrame + Vector3.new(0, 5, 0)
                
                task.wait(0.5)
                
                -- Buscar y activar prompts
                local activated = false
                for _, obj in pairs(MineralBuyer:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") then
                        fireproximityprompt(obj)
                        activated = true
                    elseif obj:IsA("ClickDetector") then
                        fireclickdetector(obj)
                        activated = true
                    end
                end
                
                task.wait(0.5)
                
                -- Volver a posición original
                HRP.CFrame = originalCFrame
                
                if activated then
                    Rayfield:Notify({
                        Title = "Éxito",
                        Content = "Minerales vendidos!",
                        Duration = 2,
                    })
                else
                    Rayfield:Notify({
                        Title = "Advertencia",
                        Content = "No se encontró botón de venta automático.",
                        Duration = 3,
                    })
                end
            else
                Rayfield:Notify({
                    Title = "Error",
                    Content = "No se pudo localizar al vendedor.",
                    Duration = 3,
                })
            end
        end)
        
        if not success then
            warn("Error en venta manual: " .. tostring(err))
        end
    end,
})

-- AUTO SELL
MainTab:CreateToggle({
    Name = "🤖 Auto-Vender (Cada 5 seg)",
    CurrentValue = false,
    Flag = "AutoSell_Ghostly",
    Callback = function(Value)
        AutoSellEnabled = Value
        
        if AutoSellEnabled then
            Rayfield:Notify({
                Title = "Auto-Venta Activada",
                Content = "Vendiendo automáticamente cada 5 segundos...",
                Duration = 3,
            })
            
            AutoSellConnection = task.spawn(function()
                while AutoSellEnabled do
                    task.wait(5)
                    
                    if not AutoSellEnabled then break end
                    
                    pcall(function()
                        local MineralBuyer = Workspace:FindFirstChild("Mineral Buyer")
                        if MineralBuyer and Player.Character and HRP then
                            local buyerPart = MineralBuyer:FindFirstChild("HumanoidRootPart") or 
                                             MineralBuyer:FindFirstChild("Head") or 
                                             MineralBuyer:FindFirstChildWhichIsA("BasePart")
                            
                            if buyerPart then
                                local originalCFrame = HRP.CFrame
                                HRP.CFrame = buyerPart.CFrame + Vector3.new(0, 5, 0)
                                
                                task.wait(0.3)
                                
                                for _, obj in pairs(MineralBuyer:GetDescendants()) do
                                    if obj:IsA("ProximityPrompt") then
                                        fireproximityprompt(obj)
                                    elseif obj:IsA("ClickDetector") then
                                        fireclickdetector(obj)
                                    end
                                end
                                
                                task.wait(0.3)
                                HRP.CFrame = originalCFrame
                            end
                        end
                    end)
                end
            end)
        else
            Rayfield:Notify({
                Title = "Auto-Venta",
                Content = "Desactivada.",
                Duration = 2,
            })
        end
    end,
})

