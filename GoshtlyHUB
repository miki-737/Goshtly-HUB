-- Función para crear botones toggle
local function CreateToggleButton(name, configKey, callback)
    local ButtonFrame = Instance.new("Frame")
    ButtonFrame.Size = UDim2.new(0.9, 0, 0, 60)
    ButtonFrame.BackgroundColor3 = Colors.Secondary
    ButtonFrame.BorderSizePixel = 0
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 10)
    ButtonCorner.Parent = ButtonFrame
    
    local ButtonStroke = Instance.new("UIStroke")
    ButtonStroke.Color = Colors.Neon
    ButtonStroke.Thickness = 1
    ButtonStroke.Parent = ButtonFrame
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Colors.Light
    Label.TextSize = 18
    Label.Font = Enum.Font.GothamBold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ButtonFrame
    
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Name = "Toggle"
    ToggleBtn.Size = UDim2.new(0, 80, 0, 40)
    ToggleBtn.Position = UDim2.new(1, -95, 0.5, -20)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    ToggleBtn.Text = "OFF"
    ToggleBtn.TextColor3 = Colors.Light
    ToggleBtn.TextSize = 16
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.Parent = ButtonFrame
    
    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 8)
    ToggleCorner.Parent = ToggleBtn
    
    local isActive = false
    
    ToggleBtn.MouseButton1Click:Connect(function()
        isActive = not isActive
        Config[configKey] = isActive
        
        if isActive then
            ToggleBtn.BackgroundColor3 = Colors.Accent
            ToggleBtn.Text = "ON"
            -- Efecto de brillo
            TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {Size = UDim2.new(0, 85, 0, 42)}):Play()
            TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {Size = UDim2.new(0, 80, 0, 40)}):Play()
        else
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
            ToggleBtn.Text = "OFF"
        end
        
        if callback then
            callback(isActive)
        end
    end)
    
    ButtonFrame.Parent = ScrollFrame
    return ButtonFrame
end

-- Función para crear botones de acción
local function CreateActionButton(name, callback, color)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0.9, 0, 0, 50)
    Button.BackgroundColor3 = color or Colors.Primary
    Button.Text = name
    Button.TextColor3 = Colors.Light
    Button.TextSize = 18
    Button.Font = Enum.Font.GothamBold
    Button.BorderSizePixel = 0
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 10)
    ButtonCorner.Parent = Button
    
    local ButtonStroke = Instance.new("UIStroke")
    ButtonStroke.Color = Colors.Light
    ButtonStroke.Thickness = 1
    ButtonStroke.Transparency = 0.5
    ButtonStroke.Parent = Button
    
    -- Efecto hover
    Button.MouseEnter:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Accent}):Play()
    end)
    
    Button.MouseLeave:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = color or Colors.Primary}):Play()
    end)
    
    Button.MouseButton1Click:Connect(function()
        -- Efecto de clic
        TweenService:Create(Button, TweenInfo.new(0.1), {Size = UDim2.new(0.85, 0, 0, 45)}):Play()
        task.wait(0.1)
        TweenService:Create(Button, TweenInfo.new(0.1), {Size = UDim2.new(0.9, 0, 0, 50)}):Play()
        
        callback()
    end)
    
    Button.Parent = ScrollFrame
    return Button
end

