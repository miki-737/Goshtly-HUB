local ToolsTab = Window:CreateTab("🔪 Armas", 4483362458)

ToolsTab:CreateSection("Selector")

-- COMBAT KNIFE
ToolsTab:CreateButton({
    Name = "🔪 Equipar Combat Knife",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local ToolsFolder = Workspace:FindFirstChild("Tools")
        
        -- Buscar en backpack
        local knife = Backpack:FindFirstChild("CombatKnife")
        if knife then
            Humanoid:EquipTool(knife)
            Rayfield:Notify({ Title = "Éxito", Content = "Combat Knife equipada!", Duration = 2 })
            return
        end
        
        -- Buscar en Tools y clonar
        if ToolsFolder then
            knife = ToolsFolder:FindFirstChild("CombatKnife")
            if knife and knife:IsA("Tool") then
                local cloned = knife:Clone()
                cloned.Parent = Backpack
                task.wait(0.1)
                Humanoid:EquipTool(cloned)
                Rayfield:Notify({ Title = "Éxito", Content = "Combat Knife obtenida!", Duration = 2 })
                return
            end
        end
        
        Rayfield:Notify({ Title = "Error", Content = "No se encontró Combat Knife", Duration = 2 })
    end,
})

-- PISTOL
ToolsTab:CreateButton({
    Name = "🔫 Equipar Pistol",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local ToolsFolder = Workspace:FindFirstChild("Tools")
        
        local pistol = Backpack:FindFirstChild("Pistol")
        if pistol then
            Humanoid:EquipTool(pistol)
            Rayfield:Notify({ Title = "Éxito", Content = "Pistol equipada!", Duration = 2 })
            return
        end
        
        if ToolsFolder then
            pistol = ToolsFolder:FindFirstChild("Pistol")
            if pistol and pistol:IsA("Tool") then
                local cloned = pistol:Clone()
                cloned.Parent = Backpack
                task.wait(0.1)
                Humanoid:EquipTool(cloned)
                Rayfield:Notify({ Title = "Éxito", Content = "Pistol obtenida!", Duration = 2 })
                return
            end
        end
        
        Rayfield:Notify({ Title = "Error", Content = "No se encontró Pistol", Duration = 2 })
    end,
})

-- OBTENER TODAS
ToolsTab:CreateButton({
    Name = "🎒 Obtener Todas las Tools",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local ToolsFolder = Workspace:FindFirstChild("Tools")
        local count = 0
        
        if ToolsFolder then
            for _, tool in pairs(ToolsFolder:GetChildren()) do
                if tool:IsA("Tool") then
                    if not Backpack:FindFirstChild(tool.Name) and not Player.Character:FindFirstChild(tool.Name) then
                        local cloned = tool:Clone()
                        cloned.Parent = Backpack
                        count = count + 1
                    end
                end
            end
        end
        
        Rayfield:Notify({ Title = "Completado", Content = "Se obtuvieron " .. count .. " tools", Duration = 2 })
    end,
})

