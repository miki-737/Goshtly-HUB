-- Encontrar ores en el juego
local function FindOres()
    local ores = {}
    
    -- Buscar en Workspace (donde están los ores físicos)
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then
            local name = obj.Name:lower()
            -- Detectar tipos de ores
            if name:find("ore") or name:find("rock") or name:find("stone") or 
               name:find("azurith") or name:find("coal") or name:find("copper") or 
               name:find("gold") or name:find("iron") or name:find("mineral") then
                table.insert(ores, obj)
            end
        end
    end
    
    return ores
end

-- Encontrar el ore más cercano
local function FindNearestOre()
    local nearest = nil
    local minDistance = math.huge
    
    for _, ore in ipairs(FindOres()) do
        if ore and ore.Parent then
            local success, distance = pcall(function()
                return (ore.Position - HumanoidRootPart.Position).Magnitude
            end)
            
            if success and distance < minDistance and distance < 200 then
                minDistance = distance
                nearest = ore
            end
        end
    end
    
    return nearest
end

-- Función para picar con daño 1000
local function MineOre(ore)
    if not ore or not ore.Parent then return end
    
    -- Teletransportar al ore
    pcall(function()
        HumanoidRootPart.CFrame = ore.CFrame * CFrame.new(0, 5, 0)
    end)
    
    -- Esperar un frame para que cargue
    task.wait(0.05)
    
    -- Intentar diferentes métodos de minado
    
    -- 1. Fire RemoteEvent comunes
    pcall(function()
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Mine"):FireServer(ore, Config.DamageAmount)
    end)
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("DamageOre"):FireServer(ore, Config.DamageAmount)
    end)
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("Mine"):FireServer(ore, Config.DamageAmount)
    end)
    
    -- 2. Usar herramienta si existe
    local tool = Character:FindFirstChildOfClass("Tool")
    if tool then
        pcall(function()
            tool:Activate()
        end)
        
        -- Modificar daño de la herramienta
        if tool:FindFirstChild("Damage") then
            tool.Damage.Value = Config.DamageAmount
        end
    end
    
    -- 3. Simular input de mouse
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.01)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
    
    -- 4. Intentar con Economy/Ores si existe
    pcall(function()
        local Economy = ReplicatedStorage:WaitForChild("Economy")
        if Economy then
            local Ores = Economy:FindFirstChild("Ores")
            if Ores then
                -- Intentar encontrar el ore en la carpeta Economy
                for _, oreData in ipairs(Ores:GetChildren()) do
                    if oreData.Name == ore.Name then
                        -- Fire server con el ore data
                        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("MineOre"):FireServer(oreData, Config.DamageAmount)
                    end
                end
            end
        end
    end)
end

-- Auto Mine Loop
local MineConnection = nil

function StartAutoMine()
    if AutoMineActive then return end
    AutoMineActive = true
    
    -- Crear hilo separado para minado
    task.spawn(function()
        while AutoMineActive do
            if not AutoMineActive then break end
            
            local ore = FindNearestOre()
            if ore then
                MineOre(ore)
            end
            
            task.wait(Config.MineDelay)
        end
    end)
    
    print("✅ Auto Minar ACTIVADO")
end

function StopAutoMine()
    AutoMineActive = false
    print("❌ Auto Minar DESACTIVADO")
end

