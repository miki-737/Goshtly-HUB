-- OBTENER TODAS LAS ARMAS
ToolsTab:CreateButton({
    Name = "🎒 Obtener Todas las Armas",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local ToolsFolder = Workspace:FindFirstChild("Tools")
        local count = 0
        
        if ToolsFolder then
            for _, tool in pairs(ToolsFolder:GetChildren()) do
                if tool:IsA("Tool") then
                    -- Verificar si ya la tiene
                    if not Backpack:FindFirstChild(tool.Name) and 
                       not (Player.Character and Player.Character:FindFirstChild(tool.Name)) then
                        local cloned = tool:Clone()
                        cloned.Parent = Backpack
                        count = count + 1
                    end
                end
            end
        end
        
        -- Listar herramientas disponibles
        local toolsList = {}
        for _, tool in pairs(Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(toolsList, tool.Name)
            end
        end
        
        if count > 0 then
            Rayfield:Notify({
                Title = "Éxito",
                Content = "Se obtuvieron " .. count .. " herramientas nuevas!",
                Duration = 3,
            })
        else
            Rayfield:Notify({
                Title = "Info",
                Content = "Ya tienes todas las herramientas disponibles.",
                Duration = 2,
            })
        end
    end,
})

