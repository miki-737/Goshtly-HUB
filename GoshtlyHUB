local Hacks = {
    -- 1. SISTEMA DE VENTA AUTOMÁTICA (Midnight Special SellOre)
    SellSystem = {
        Remote = nil,
        
        Initialize = function()
            -- Buscar el remote de venta
            local success, remote = pcall(function()
                return ReplicatedStorage:FindFirstChild("Midnight Special SellOre", true)
                    or ReplicatedStorage:WaitForChild("Midnight Special SellOre", 5)
            end)
            
            if success and remote then
                Hacks.SellSystem.Remote = remote
                NotificationSystem.Show("Sistema de Venta", "Remote conectado: Midnight Special SellOre", "SUCCESS", 3)
                return true
            else
                -- Buscar alternativas
                for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
                    if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                        if obj.Name:lower():find("sell") and obj.Name:lower():find("ore") then
                            Hacks.SellSystem.Remote = obj
                            NotificationSystem.Show("Sistema de Venta", "Remote alternativo encontrado: " .. obj.Name, "WARNING", 3)
                            return true
                        end
                    end
                end
            end
            
            NotificationSystem.Show("Sistema de Venta", "No se encontró el remote de venta", "ERROR", 3)
            return false
        end,
        
        SellAll = function()
            if not Hacks.SellSystem.Remote then
                if not Hacks.SellSystem.Initialize() then return false end
            end
            
            local success, result = pcall(function()
                -- Intentar diferentes métodos de fire
                if Hacks.SellSystem.Remote:IsA("RemoteEvent") then
                    Hacks.SellSystem.Remote:FireServer("SellAll")
                    Hacks.SellSystem.Remote:FireServer()
                elseif Hacks.SellSystem.Remote:IsA("RemoteFunction") then
                    Hacks.SellSystem.Remote:InvokeServer("SellAll")
                end
            end)
            
            if success then
                SoundSystem.Play("SELL", 0.6)
                NotificationSystem.Show("Venta Exitosa", "Todos los minerales vendidos", "SUCCESS", 2)
                return true
            else
                NotificationSystem.Show("Error de Venta", tostring(result), "ERROR", 3)
                return false
            end
        end,
        
        AutoSell = function(enabled)
            if enabled then
                spawn(function()
                    while GhostlyHub.EnabledFeatures.AutoSell do
                        -- Verificar si está cerca del vendedor
                        local nearSeller = false
                        local sellerPosition = nil
                        
                        pcall(function()
                            for _, obj in ipairs(Workspace:GetDescendants()) do
                                if obj:IsA("Model") and (obj.Name:lower():find("seller") 
                                    or obj.Name:lower():find("merchant")
                                    or obj.Name:lower():find("midnight")
                                    or obj.Name:lower():find("shop")) then
                                    local part = obj:FindFirstChild("HumanoidRootPart") 
                                        or obj:FindFirstChild("Head")
                                        or obj:FindFirstChildWhichIsA("BasePart")
                                    
                                    if part and HumanoidRootPart then
                                        local dist = (part.Position - HumanoidRootPart.Position).Magnitude
                                        if dist < 20 then
                                            nearSeller = true
                                            sellerPosition = part.Position
                                            break
                                        end
                                    end
                                end
                            end
                        end)
                        
                        if nearSeller then
                            Hacks.SellSystem.SellAll()
                        end
                        
                        task.wait(2)
                    end
                end)
            end
        end
    },
    
    -- 2. SISTEMA DE COMIDA (Tasks > Cook > Food)
    FoodSystem = {
        Remote = nil,
        FolderPath = nil,
        
        Initialize = function()
            -- Buscar la estructura Tasks > Cook > Food
            local tasks = ReplicatedStorage:FindFirstChild("Tasks")
                or Workspace:FindFirstChild("Tasks")
            
            if tasks then
                local cook = tasks:FindFirstChild("Cook")
                if cook then
                    local food = cook:FindFirstChild("Food")
                    if food then
                        Hacks.FoodSystem.FolderPath = food
                        
                        -- Buscar remotes dentro
                        for _, obj in ipairs(food:GetDescendants()) do
                            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                                Hacks.FoodSystem.Remote = obj
                                NotificationSystem.Show("Sistema de Comida", 
                                    "Conectado: Tasks > Cook > Food > " .. obj.Name, "SUCCESS", 3)
                                return true
                            end
                        end
                    end
                end
            end
            
            -- Búsqueda general de remotes de comida
            for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    if obj.Name:lower():find("food") or obj.Name:lower():find("hunger") 
                        or obj.Name:lower():find("eat") then
                        Hacks.FoodSystem.Remote = obj
                        NotificationSystem.Show("Sistema de Comida", 
                            "Remote encontrado: " .. obj.Name, "WARNING", 3)
                        return true
                    end
                end
            end
            
            return false
        end,
        
        NoHunger = function(enabled)
            if enabled then
                -- Método 1: Bloquear remote de disminución
                -- Método 2: Mantener valores al máximo
                spawn(function()
                    while GhostlyHub.EnabledFeatures.NoHunger do
                        pcall(function()
                            -- Buscar valores de hambre en el jugador
                            local stats = LocalPlayer:FindFirstChild("Stats")
                                or LocalPlayer:FindFirstChild("Data")
                                or LocalPlayer:FindFirstChild("PlayerData")
                            
                            if stats then
                                local hunger = stats:FindFirstChild("Hunger") 
                                    or stats:FindFirstChild("Food")
                                    or stats:FindFirstChild("Hambre")
                                
                                if hunger and hunger:IsA("ValueBase") then
                                    hunger.Value = hunger.MaxValue or 100
                                end
                            end
                            
                            -- También buscar en character
                            if Character then
                                local charHunger = Character:FindFirstChild("Hunger")
                                    or Character:FindFirstChild("Food")
                                if charHunger and charHunger:IsA("ValueBase") then
                                    charHunger.Value = 100
                                end
                            end
                        end)
                        task.wait(0.5)
                    end
                end)
                
                NotificationSystem.Show("No Hunger", "Tu comida ya no bajará", "SUCCESS", 2)
            end
        end,
        
        NoThirst = function(enabled)
            if enabled then
                spawn(function()
                    while GhostlyHub.EnabledFeatures.NoThirst do
                        pcall(function()
                            local stats = LocalPlayer:FindFirstChild("Stats")
                                or LocalPlayer:FindFirstChild("Data")
                            
                            if stats then
                                local thirst = stats:FindFirstChild("Thirst") 
                                    or stats:FindFirstChild("Water")
                                    or stats:FindFirstChild("Sed")
                                
                                if thirst and thirst:IsA("ValueBase") then
                                    thirst.Value = thirst.MaxValue or 100
                                end
                            end
                        end)
                        task.wait(0.5)
                    end
                end)
                
                NotificationSystem.Show("No Thirst", "Tu sed ya no bajará", "SUCCESS", 2)
            end
        end,
        
        AutoCook = function(enabled)
            if enabled then
                spawn(function()
                    while GhostlyHub.EnabledFeatures.AutoCook do
                        pcall(function()
                            if Hacks.FoodSystem.Remote then
                                -- Intentar cocinar automáticamente
                                Hacks.FoodSystem.Remote:FireServer("Cook", "BestFood")
                            end
                        end)
                        task.wait(5)
                    end
                end)
            end
        end
    },
    
    -- 3. SISTEMA DE MINERÍA INSTANTÁNEA
    MiningSystem = {
        Remote = nil,
        
        Initialize = function()
            -- Buscar remote de minería
            for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    if obj.Name:lower():find("mine") or obj.Name:lower():find("pick") 
                        or obj.Name:lower():find("rock") or obj.Name:lower():find("ore") then
                        Hacks.MiningSystem.Remote = obj
                        return true
                    end
                end
            end
            return false
        end,
        
        InstantMine = function(enabled)
            if enabled then
                spawn(function()
                    while GhostlyHub.EnabledFeatures.InstantMine do
                        pcall(function()
                            -- Método 1: Auto-click en rocas cercanas
                            local tool = Character:FindFirstChildOfClass("Tool")
                            if tool then
                                local handle = tool:FindFirstChild("Handle")
                                if handle then
                                    -- Activar remote si existe
                                    if Hacks.MiningSystem.Remote then
                                        for _ = 1, 5 do -- 5 golpes rápidos
                                            Hacks.MiningSystem.Remote:FireServer()
                                            task.wait(0.05)
                                        end
                                    end
                                end
                            end
                            
                            -- Método 2: Animación ultra rápida
                            local animator = Humanoid:FindFirstChild("Animator")
                            if animator then
                                for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                                    track:AdjustSpeed(20) -- 20x velocidad
                                end
                            end
                        end)
                        task.wait(0.1)
                    end
                end)
                
                NotificationSystem.Show("Instant Mine", "Picando a velocidad máxima", "SUCCESS", 2)
            else
                -- Restaurar velocidad de animaciones
                pcall(function()
                    local animator = Humanoid:FindFirstChild("Animator")
                    if animator then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            track:AdjustSpeed(1)
                        end
                    end
                end)
            end
        end
    },
    
    -- 4. NOCLIP MEJORADO
    NoclipSystem = {
        Connection = nil,
        OriginalCollisions = {},
        
        Toggle = function(enabled)
            if enabled then
                GhostlyHub.EnabledFeatures.Noclip = true
                
                -- Guardar estado original
                Hacks.NoclipSystem.OriginalCollisions = {}
                
                Hacks.NoclipSystem.Connection = RunService.Stepped:Connect(function()
                    if Character and GhostlyHub.EnabledFeatures.Noclip then
                        for _, part in ipairs(Character:GetDescendants()) do
                            if part:IsA("BasePart") then
                                if not Hacks.NoclipSystem.OriginalCollisions[part] then
                                    Hacks.NoclipSystem.OriginalCollisions[part] = part.CanCollide
                                end
                                part.CanCollide = false
                            end
                        end
                    end
                end)
                
                NotificationSystem.Show("Noclip", "Atravesando paredes (Tecla V)", "SUCCESS", 2)
            else
                GhostlyHub.EnabledFeatures.Noclip = false
                if Hacks.NoclipSystem.Connection then
                    Hacks.NoclipSystem.Connection:Disconnect()
                    Hacks.NoclipSystem.Connection = nil
                end
                
                -- Restaurar colisiones
                for part, original in pairs(Hacks.NoclipSystem.OriginalCollisions) do
                    if part and part.Parent then
                        part.CanCollide = original
                    end
                end
                Hacks.NoclipSystem.OriginalCollisions = {}
                
                NotificationSystem.Show("Noclip", "Colisiones restauradas", "INFO", 2)
            end
        end
    },
    
    -- 5. EXTRAS PROFESIONALES
    Extras = {
        InfiniteStamina = function(enabled)
            if enabled then
                spawn(function()
                    while GhostlyHub.EnabledFeatures.InfiniteStamina do
                        pcall(function()
                            local stamina = LocalPlayer:FindFirstChild("Stamina", true)
                                or Character:FindFirstChild("Stamina", true)
                            if stamina and stamina:IsA("ValueBase") then
                                stamina.Value = stamina.MaxValue or 100
                            end
                        end)
                        task.wait(0.2)
                    end
                end)
            end
        end,
        
        FastWalk = function(enabled)
            if enabled then
                pcall(function()
                    Humanoid.WalkSpeed = 100
                end)
            else
                pcall(function()
                    Humanoid.WalkSpeed = 16
                end)
            end
        end,
        
        GodMode = function(enabled)
            -- Prevenir daño
            if enabled then
                local conn = Humanoid:GetPropertyChangedSignal("Health"):Connect(function()
                    if Humanoid.Health < Humanoid.MaxHealth then
                        Humanoid.Health = Humanoid.MaxHealth
                    end
                end)
                table.insert(GhostlyHub.Connections, conn)
            end
        end
    }
}

