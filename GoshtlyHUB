local MiningTab = Window:CreateTab("⛏️ Minería", 4483362458)

MiningTab:CreateSection("Herramientas")

-- EQUIPAR PICKAXE
MiningTab:CreateButton({
    Name = "🎒 Equipar Pickaxe",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local pickaxe = Backpack:FindFirstChild("Pickaxe")
        
        if pickaxe then
            Humanoid:EquipTool(pickaxe)
            Rayfield:Notify({ Title = "Éxito", Content = "Pickaxe equipada!", Duration = 2 })
        elseif Player.Character:FindFirstChild("Pickaxe") then
            Rayfield:Notify({ Title = "Info", Content = "Ya equipada", Duration = 2 })
        else
            Rayfield:Notify({ Title = "Error", Content = "No tienes Pickaxe", Duration = 2 })
        end
    end,
})

-- SUPER PICKAXE
MiningTab:CreateToggle({
    Name = "⚡ Super Pickaxe (Rápido)",
    CurrentValue = false,
    Flag = "SuperPickaxe_Ghostly",
    Callback = function(Value)
        SuperPickaxeEnabled = Value
        
        if SuperPickaxeEnabled then
            Rayfield:Notify({ Title = "Super Pickaxe", Content = "Activado!", Duration = 2 })
            
            task.spawn(function()
                while SuperPickaxeEnabled do
                    task.wait(0.1)
                    if not SuperPickaxeEnabled then break end
                    
                    local Character = Player.Character
                    if not Character then continue end
                    
                    local tool = Character:FindFirstChildOfClass("Tool")
                    if tool and (tool.Name == "Pickaxe" or tool.Name:lower():find("pick")) then
                        if tool.Activate then tool:Activate() end
                        
                        -- Golpear rocas en Prisones>Rocks
                        local Prisones = Workspace:FindFirstChild("Prisones")
                        if Prisones then
                            local Rocks = Prisones:FindFirstChild("Rocks")
                            if Rocks and HRP then
                                for _, rock in pairs(Rocks:GetChildren()) do
                                    if rock.Name == "Part" and rock:IsA("BasePart") then
                                        if (rock.Position - HRP.Position).Magnitude < 12 then
                                            if firetouchinterest then
                                                firetouchinterest(HRP, rock, 0)
                                                firetouchinterest(HRP, rock, 1)
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        else
            Rayfield:Notify({ Title = "Super Pickaxe", Content = "Desactivado", Duration = 2 })
        end
    end,
})

-- AUTO MINAR
MiningTab:CreateToggle({
    Name = "🤖 Auto-Minar",
    CurrentValue = false,
    Flag = "AutoMine_Ghostly",
    Callback = function(Value)
        AutoMineEnabled = Value
        
        if AutoMineEnabled then
            Rayfield:Notify({ Title = "Auto-Minar", Content = "Activado", Duration = 2 })
            
            task.spawn(function()
                while AutoMineEnabled do
                    task.wait(0.2)
                    if not AutoMineEnabled then break end
                    if not Player.Character then continue end
                    
                    local tool = Player.Character:FindFirstChildOfClass("Tool")
                    if tool and (tool.Name == "Pickaxe" or tool.Name:lower():find("pick")) then
                        if tool.Activate then tool:Activate() end
                    end
                end
            end)
        else
            Rayfield:Notify({ Title = "Auto-Minar", Content = "Desactivado", Duration = 2 })
        end
    end,
})

