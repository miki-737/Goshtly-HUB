-- 4. Botón de Gestión de Herramientas (Más complejo, usamos un botón maestro)
local ToolsBtn = CrearBoton("🔪 Select Tool", 150, function()
    UpdateDisplay("⚙️ Selector de Tools", "Elige qué herramienta deseas equipar:")
    
    -- Aquí puedes crear botones dinámicos para cada tool:
    local folder = Instance.new("Frame")
    folder.Parent = Content
    folder.Size = UDim2.new(1, 0, 0, 150) -- Área de selección temporal
    
    local toolsFolder = workspace:FindFirstChild("Tools")

    if toolsFolder then
        for _, tool in ipairs(toolsFolder:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name == "CombatKnife" or tool.Name == "Pistol") then
                local Btn = Instance.new("TextButton")
                Btn.Size = UDim2.new(1, 0, 0, 40)
                Btn.Position = UDim2.new(0, 0, (math.floor((#toolsFolder)/2 - 1)*50), 0) -- Posicionamiento básico
                Btn.Text = tool.Name .. " (Equipar)"
                Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
                Btn.Parent = folder
                
                local connection = Btn.MouseButton1Click:Connect(function()
                    SelectTool(tool.Name) -- Llama a la función de selección
                    -- Desactivar/limpiar el selector después del uso
                    folder.Visible = false 
                end)
            end
        end
        folder.Visible = true

    else
         UpdateDisplay("🛠️ Selector de Tools", "Error: La carpeta 'Tools' no fue encontrada en Workspace.")
    end
end)


