if game.PlaceId == 81223687051453 then

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({

Name = "GhostlyHUB",

LoadingTitle = "GhostlyHUB",

LoadingSubtitle = "Sistema privado",

ConfigurationSaving = {
    Enabled = true,
    FolderName = "GhostlyHUB",
    FileName = "Config"
},

Discord = {
    Enabled = false
},

KeySystem = false

})


-- TAB PRINCIPAL

local Main = Window:CreateTab("🏠 Principal", 4483362458)


local noclip = false


Main:CreateToggle({

Name = "Noclip",

CurrentValue = false,

Callback = function(Value)

noclip = Value

end

})


game:GetService("RunService").Stepped:Connect(function()

if noclip then

local char = game.Players.LocalPlayer.Character

if char then

for _,part in pairs(char:GetDescendants()) do

if part:IsA("BasePart") then

part.CanCollide = false

end

end

end

end

end)



-- MINERIA

local Mining = Window:CreateTab("⛏️ Minería",4483362458)



Mining:CreateButton({

Name = "Equipar Pickaxe",

Callback = function()

local tool = game.ReplicatedStorage.Tools:FindFirstChild("Pickaxe")

if tool then

tool:Clone().Parent =
game.Players.LocalPlayer.Backpack

end

end

})


Mining:CreateButton({

Name = "Mejorar daño Pickaxe",

Callback = function()

local pickaxe =
game.Players.LocalPlayer.Backpack:FindFirstChild("Pickaxe")


if pickaxe then

pickaxe:SetAttribute("Damage",999)

end


end

})



-- VENTA

local Sell = Window:CreateTab("💰 Venta",4483362458)



Sell:CreateButton({

Name = "Vender minerales",

Callback=function()


local npc =
workspace:FindFirstChild("Mineral Buyer")


if npc then

local prompt =
npc:FindFirstChildWhichIsA("ProximityPrompt",true)


