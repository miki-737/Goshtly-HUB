-- Sistema de notificaciones flotantes
local NotificationSystem = {
    ActiveNotifications = {},
    
    Show = function(title, message, notificationType, duration)
        local notifType = notificationType or "INFO"
        local colors = {
            SUCCESS = CONFIG.COLORS.ON,
            ERROR = CONFIG.COLORS.OFF,
            WARNING = CONFIG.COLORS.WARNING,
            INFO = CONFIG.COLORS.INFO
        }
        
        local notif = Instance.new("ScreenGui")
        notif.Name = "GhostlyNotification"
        notif.ResetOnSpawn = false
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0, 320, 0, 80)
        frame.Position = UDim2.new(1, 20, 0, 20 + (#NotificationSystem.ActiveNotifications * 90))
        frame.BackgroundColor3 = CONFIG.COLORS.BACKGROUND
        frame.BorderSizePixel = 0
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 12)
        corner.Parent = frame
        
        local stroke = Instance.new("UIStroke")
        stroke.Color = colors[notifType] or CONFIG.COLORS.ACCENT
        stroke.Thickness = 2
        stroke.Parent = frame
        
        local icon = Instance.new("TextLabel")
        icon.Size = UDim2.new(0, 40, 0, 40)
        icon.Position = UDim2.new(0, 15, 0, 20)
        icon.BackgroundTransparency = 1
        icon.Text = notifType == "SUCCESS" and "✓" or notifType == "ERROR" and "✕" or notifType == "WARNING" and "!" or "ℹ"
        icon.TextColor3 = colors[notifType] or CONFIG.COLORS.ACCENT
        icon.TextSize = 30
        icon.Font = Enum.Font.GothamBold
        icon.Parent = frame
        
        local titleLabel = Instance.new("TextLabel")
        titleLabel.Size = UDim2.new(1, -70, 0, 25)
        titleLabel.Position = UDim2.new(0, 60, 0, 10)
        titleLabel.BackgroundTransparency = 1
        titleLabel.Text = title
        titleLabel.TextColor3 = CONFIG.COLORS.TEXT
        titleLabel.TextSize = 16
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.Parent = frame
        
        local msgLabel = Instance.new("TextLabel")
        msgLabel.Size = UDim2.new(1, -70, 0, 40)
        msgLabel.Position = UDim2.new(0, 60, 0, 35)
        msgLabel.BackgroundTransparency = 1
        msgLabel.Text = message
        msgLabel.TextColor3 = CONFIG.COLORS.TEXT_DIM
        msgLabel.TextSize = 12
        msgLabel.Font = Enum.Font.Gotham
        msgLabel.TextXAlignment = Enum.TextXAlignment.Left
        msgLabel.TextWrapped = true
        msgLabel.Parent = frame
        
        notif.Parent = game:GetService("CoreGui") or LocalPlayer.PlayerGui
        
        -- Animación de entrada
        TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
            Position = UDim2.new(1, -340, 0, frame.Position.Y.Offset)
        }):Play()
        
        table.insert(NotificationSystem.ActiveNotifications, notif)
        
        -- Auto-destruir
        task.delay(duration or 3, function()
            TweenService:Create(frame, TweenInfo.new(0.3), {
                Position = UDim2.new(1, 20, 0, frame.Position.Y.Offset)
            }):Play()
            task.wait(0.3)
            notif:Destroy()
            
            -- Reorganizar notificaciones restantes
            for i, n in ipairs(NotificationSystem.ActiveNotifications) do
                if n == notif then
                    table.remove(NotificationSystem.ActiveNotifications, i)
                    break
                end
            end
            
            -- Actualizar posiciones
            for i, activeNotif in ipairs(NotificationSystem.ActiveNotifications) do
                local f = activeNotif:FindFirstChildOfClass("Frame")
                if f then
                    TweenService:Create(f, TweenInfo.new(0.3), {
                        Position = UDim2.new(1, -340, 0, 20 + ((i-1) * 90))
                    }):Play()
                end
            end
        end)
    end
}

-- Función tween simplificada
local function Tween(object, properties, duration, style, direction)
    return TweenService:Create(object, TweenInfo.new(
        duration or CONFIG.ANIMATION.SPEED,
        style or CONFIG.ANIMATION.QUART,
        direction or Enum.EasingDirection.Out
    ), properties)
end

