local MainTab = Window:CreateTab("🏠 Principal", 4483362458)

MainTab:CreateSection("Movimiento")

-- NOCLIP
MainTab:CreateToggle({
    Name = "👻 Noclip (Atravesar Paredes)",
    CurrentValue = false,
    Flag = "Noclip_Ghostly",
    Callback = function(Value)
        NoclipEnabled = Value
        
        if NoclipEnabled then
            Rayfield:Notify({ Title = "Noclip", Content = "Activado!", Duration = 2 })
            
            NoclipConnection = RunService.Stepped:Connect(function()
                if not NoclipEnabled then return end
                if Player.Character then
                    for _, part in pairs(Player.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        else
            Rayfield:Notify({ Title = "Noclip", Content = "Desactivado", Duration = 2 })
            if NoclipConnection then
                NoclipConnection:Disconnect()
                NoclipConnection = nil
            end
            if Player.Character then
                for _, part in pairs(Player.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.CanCollide = true
                    end
                end
            end
        end
    end,
})

MainTab:CreateSection("Venta")

-- VENDER MANUAL
MainTab:CreateButton({
    Name = "💰 Vender Ahora (Mineral Buyer)",
    Callback = function()
        local MineralBuyer = Workspace:FindFirstChild("Mineral Buyer")
        
        if not MineralBuyer then
            Rayfield:Notify({ Title = "Error", Content = "No se encontró Mineral Buyer", Duration = 3 })
            return
        end
        
        if not HRP then return end
        
        local originalCFrame = HRP.CFrame
        local buyerPart = MineralBuyer:FindFirstChild("HumanoidRootPart") or 
                         MineralBuyer:FindFirstChild("Head") or 
                         MineralBuyer:FindFirstChildWhichIsA("BasePart")
        
        if buyerPart then
            HRP.CFrame = buyerPart.CFrame + Vector3.new(0, 5, 0)
            task.wait(0.5)
            
            for _, obj in pairs(MineralBuyer:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    fireproximityprompt(obj)
                elseif obj:IsA("ClickDetector") then
                    fireclickdetector(obj)
                end
            end
            
            task.wait(0.5)
            HRP.CFrame = originalCFrame
            
            Rayfield:Notify({ Title = "Éxito", Content = "Minerales vendidos!", Duration = 2 })
        end
    end,
})

-- AUTO VENDER
MainTab:CreateToggle({
    Name = "🤖 Auto-Vender",
    CurrentValue = false,
    Flag = "AutoSell_Ghostly",
    Callback = function(Value)
        AutoSellEnabled = Value
        
        if AutoSellEnabled then
            Rayfield:Notify({ Title = "Auto-Venta", Content = "Activada (cada 5s)", Duration = 2 })
            
            AutoSellThread = task.spawn(function()
                while AutoSellEnabled do
                    task.wait(5)
                    if not AutoSellEnabled then break end
                    
                    pcall(function()
                        local MineralBuyer = Workspace:FindFirstChild("Mineral Buyer")
                        if MineralBuyer and HRP then
                            local buyerPart = MineralBuyer:FindFirstChild("HumanoidRootPart") or 
                                             MineralBuyer:FindFirstChild("Head") or 
                                             MineralBuyer:FindFirstChildWhichIsA("BasePart")
                            
                            if buyerPart then
                                local original = HRP.CFrame
                                HRP.CFrame = buyerPart.CFrame + Vector3.new(0, 5, 0)
                                task.wait(0.3)
                                
                                for _, obj in pairs(MineralBuyer:GetDescendants()) do
                                    if obj:IsA("ProximityPrompt") then
                                        fireproximityprompt(obj)
                                    elseif obj:IsA("ClickDetector") then
                                        fireclickdetector(obj)
                                    end
                                end
                                
                                task.wait(0.3)
                                HRP.CFrame = original
                            end
                        end
                    end)
                end
            end)
        else
            Rayfield:Notify({ Title = "Auto-Venta", Content = "Desactivada", Duration = 2 })
        end
    end,
})

