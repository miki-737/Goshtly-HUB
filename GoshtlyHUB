-- Función para crear botón con icono
function UI.CreateIconButton(parent, text, position, color, size)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, size or 35, 0, size or 35)
    btn.Position = position
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = CONFIG.COLORS.TEXT
    btn.TextSize = 20
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 3
    btn.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
    -- Hover
    btn.MouseEnter:Connect(function()
        Tween(btn, {BackgroundColor3 = color:Lerp(Color3.new(1,1,1), 0.2)}, 0.2):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        Tween(btn, {BackgroundColor3 = color}, 0.2):Play()
    end)
    
    return btn
end

