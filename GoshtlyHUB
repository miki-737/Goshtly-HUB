    TitleLabel.Parent = ActionFrame
    
    -- Descripción
    local DescLabel = Instance.new("TextLabel")
    DescLabel.Size = UDim2.new(1, -140, 0, 40)
    DescLabel.Position = UDim2.new(0, 15, 0, 50)
    DescLabel.BackgroundTransparency = 1
    DescLabel.Text = description
    DescLabel.TextColor3 = CONFIG.COLORS.TEXT_DIM
    DescLabel.TextSize = 12
    DescLabel.Font = Enum.Font.Gotham
    DescLabel.TextXAlignment = Enum.TextXAlignment.Left
    DescLabel.TextWrapped = true
    DescLabel.Parent = ActionFrame
    
    -- Botón principal
    local ActionBtn = Instance.new("TextButton")
    ActionBtn.Size = UDim2.new(0, 110, 0, 45)
    ActionBtn.Position = UDim2.new(1, -125, 0.5, -22)
    ActionBtn.BackgroundColor3 = Color3.new(1, 1, 1)
    ActionBtn.Text = "EJECUTAR"
    ActionBtn.TextColor3 = Color3.fromRGB(30, 10, 50)
    ActionBtn.TextSize = 14
    ActionBtn.Font = Enum.Font.GothamBlack
    ActionBtn.Parent = ActionFrame
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 12)
    BtnCorner.Parent = ActionBtn
    
    -- Indicador de estado
    local StatusDot = Instance.new("Frame")
    StatusDot.Size = UDim2.new(0, 12, 0, 12)
    StatusDot.Position = UDim2.new(1, -30, 0, 15)
    StatusDot.BackgroundColor3 = CONFIG.COLORS.OFF
    StatusDot.BorderSizePixel = 0
    StatusDot.Parent = ActionFrame
    
    local DotCorner = Instance.new("UICorner")
    DotCorner.CornerRadius = UDim.new(1, 0)
    DotCorner.Parent = StatusDot
    
    -- Verificar proximidad al vendedor
    spawn(function()
        while ActionFrame and ActionFrame.Parent do
            local near = false
            pcall(function()
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("Model") then
                        if obj.Name:lower():find("sell") or 
                           obj.Name:lower():find("merchant") or
                           obj.Name:lower():find("midnight") then
                            local part = obj:FindFirstChildWhichIsA("BasePart")
                            if part and HumanoidRootPart then
                                if (part.Position - HumanoidRootPart.Position).Magnitude < 15 then
                                    near = true
                                    break
                                end
                            end
                        end
                    end
                end
            end)
            
            StatusDot.BackgroundColor3 = near and CONFIG.COLORS.ON or CONFIG.COLORS.OFF
            
            if near then
                ActionBtn.Text = "💰 VENDER"
                ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
            else
                ActionBtn.Text = "ACÉRCATE"
                ActionBtn.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
            end
            
            task.wait(0.5)
        end
    end)
    
    ActionBtn.MouseButton1Click:Connect(function()
        Tween(ActionBtn, {Size = UDim2.new(0, 105, 0, 42)}, 0.1):Play()
        task.wait(0.1)
        Tween(ActionBtn, {Size = UDim2.new(0, 110, 0, 45)}, 0.1):Play()
        
        callback()
    end)
    
    return ActionFrame
end

