-- COMBAT KNIFE
ToolsTab:CreateButton({
    Name = "🔪 Equipar Combat Knife",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local ToolsFolder = Workspace:FindFirstChild("Tools")
        
        -- Intentar equipar desde backpack primero
        local knife = Backpack:FindFirstChild("CombatKnife")
