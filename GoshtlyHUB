-- SUPER PICKAXE (DAÑO AUMENTADO)
MiningTab:CreateToggle({
    Name = "⚡ Super Pickaxe (Golpes Rápidos)",
    CurrentValue = false,
    Flag = "SuperPickaxe_Ghostly",
    Callback = function(Value)
        SuperPickaxeEnabled = Value
        
        if SuperPickaxeEnabled then
            Rayfield:Notify({
                Title = "Super Pickaxe",
                Content = "Modo rápido activado! Golpea más veces por segundo.",
                Duration = 3,
            })
            
            SuperPickaxeConnection = task.spawn(function()
                while SuperPickaxeEnabled do
                    task.wait(0.1) -- 10 golpes por segundo
                    
                    if not SuperPickaxeEnabled then break end
                    
                    pcall(function()
                        local Character = Player.Character
                        if not Character then return end
                        
                        local tool = Character:FindFirstChildOfClass("Tool")
                        if tool and (tool.Name == "Pickaxe" or tool.Name:lower():find("pick")) then
                            -- Activar herramienta
                            if tool.Activate then
                                tool:Activate()
                            end
                            
                            -- Buscar rocas cercanas y golpear
                            local Prisones = Workspace:FindFirstChild("Prisones")
                            if Prisones then
                                local Rocks = Prisones:FindFirstChild("Rocks")
                                if Rocks and HRP then
                                    for _, rock in pairs(Rocks:GetChildren()) do
                                        if rock.Name == "Part" and rock:IsA("BasePart") then
                                            local distance = (rock.Position - HRP.Position).Magnitude
                                            if distance < 12 then
                                                -- Simular múltiples golpes
                                                if firetouchinterest then
                                                    firetouchinterest(HRP, rock, 0)
                                                    firetouchinterest(HRP, rock, 1)
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end)
                end
            end)
        else
            Rayfield:Notify({
                Title = "Super Pickaxe",
                Content = "Modo normal restaurado.",
                Duration = 2,
            })
        end
    end,
})

-- AUTO MINAR (Golpea automáticamente rocas cercanas)
MiningTab:CreateToggle({
    Name = "🤖 Auto-Minar (Golpea Rocas)",
    CurrentValue = false,
    Flag = "AutoMine_Ghostly",
    Callback = function(Value)
        AutoMineEnabled = Value
        
        if AutoMineEnabled then
            Rayfield:Notify({
                Title = "Auto-Minar",
                Content = "Golpeando rocas automáticamente...",
                Duration = 3,
            })
            
            task.spawn(function()
                while AutoMineEnabled do
                    task.wait(0.2)
                    
                    if not AutoMineEnabled then break end
                    if not Player.Character then continue end
                    if not HRP then continue end
                    
                    local tool = Player.Character:FindFirstChildOfClass("Tool")
                    if tool and (tool.Name == "Pickaxe" or tool.Name:lower():find("pick")) then
                        if tool.Activate then
                            tool:Activate()
                        end
                    end
                end
            end)
        else
            Rayfield:Notify({
                Title = "Auto-Minar",
                Content = "Desactivado.",
                Duration = 2,
            })
        end
    end,
})

