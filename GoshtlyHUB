                cloned.Parent = Backpack
                task.wait(0.1)
                Humanoid:EquipTool(cloned)
                Rayfield:Notify({
                    Title = "Éxito",
                    Content = "Combat Knife obtenida y equipada!",
                    Duration = 2,
                })
                return
            end
        end
        
        -- Verificar si ya está equipada
        if Player.Character and Player.Character:FindFirstChild("CombatKnife") then
            Rayfield:Notify({
                Title = "Info",
                Content = "Ya tienes la Combat Knife equipada.",
                Duration = 2,
            })
            return
        end
        
        Rayfield:Notify({
            Title = "Error",
            Content = "No se encontró Combat Knife.",
            Duration = 3,
        })
    end,
})

