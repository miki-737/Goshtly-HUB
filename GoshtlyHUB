-- VARIABLES GLOBALES
-- ═══════════════════════════════════════════════════
local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local HRP = Character:WaitForChild("HumanoidRootPart")

local NoclipEnabled = false
local SuperPickaxeEnabled = false
local AutoSellEnabled = false
local AutoSellConnection = nil

-- ═══════════════════════════════════════════════════
-- PESTAÑA: MAIN (Noclip & AutoSell)
-- ═══════════════════════════════════════════════════
local MainTab = Window:CreateTab("🏠 Inicio", "home")

MainTab:CreateSection("Movimiento & Utilidades")

-- NOCLIP TOGGLE
local NoclipToggle = MainTab:CreateToggle({
    Name = "👻 Noclip (Atravesar Paredes)",
    CurrentValue = false,
    Flag = "NoclipEnabled",
    Callback = function(Value)
        NoclipEnabled = Value
        
        if NoclipEnabled then
            Rayfield:Notify({
                Title = "Noclip Activado",
                Content = "Ahora puedes atravesar paredes y objetos!",
                Duration = 3,
                Image = "ghost"
            })
            
            -- Loop de Noclip
            task.spawn(function()
                while NoclipEnabled do
                    if Player.Character then
                        for _, part in pairs(Player.Character:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end
                    task.wait(0.1)
                end
                
                -- Restaurar colisión al desactivar
                if Player.Character then
                    for _, part in pairs(Player.Character:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                            part.CanCollide = true
                        end
                    end
                end
            end)
        else
            Rayfield:Notify({
                Title = "Noclip Desactivado",
                Content = "Colisión restaurada.",
                Duration = 2
            })
        end
    end,
})

MainTab:CreateSection("Venta Automática")

-- AUTO SELL TOGGLE
local AutoSellToggle = MainTab:CreateToggle({
    Name = "💰 Auto Vender (Mineral Buyer)",
    CurrentValue = false,
    Flag = "AutoSellEnabled",
    Callback = function(Value)
        AutoSellEnabled = Value
        
        if AutoSellEnabled then
            Rayfield:Notify({
                Title = "Auto-Sell Activado",
                Content = "Buscando Mineral Buyer...",
                Duration = 3
            })
            
            AutoSellConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if not AutoSellEnabled then return end
                
                local MineralBuyer = workspace:FindFirstChild("Mineral Buyer")
                if MineralBuyer and Player.Character and HRP then
                    local BuyerPart = MineralBuyer:FindFirstChild("HumanoidRootPart") or 
                                     MineralBuyer:FindFirstChild("Head") or 
                                     MineralBuyer:FindFirstChildWhichIsA("Part")
                    
                    if BuyerPart then
                        -- Teletransportar cerca del vendedor
                        local originalPos = HRP.CFrame
                        HRP.CFrame = BuyerPart.CFrame + Vector3.new(0, 3, 0)
                        
                        -- Buscar y activar ProximityPrompt
                        task.wait(0.2)
                        for _, obj in pairs(MineralBuyer:GetDescendants()) do
                            if obj:IsA("ProximityPrompt") then
                                fireproximityprompt(obj)
                            end
                            if obj:IsA("ClickDetector") then
                                fireclickdetector(obj)
                            end
                        end
                        
                        task.wait(0.3)
                        HRP.CFrame = originalPos
                    end
                end
                
                task.wait(5) -- Esperar 5 segundos entre ventas
            end)
        else
            if AutoSellConnection then
                AutoSellConnection:Disconnect()
                AutoSellConnection = nil
            end
            Rayfield:Notify({
                Title = "Auto-Sell Desactivado",
                Content = "Ventas automáticas detenidas.",
                Duration = 2
            })
        end
    end,
})

-- BOTÓN MANUAL DE VENTA
MainTab:CreateButton({
    Name = "💸 Vender Ahora (Manual)",
    Callback = function()
        local MineralBuyer = workspace:FindFirstChild("Mineral Buyer")
        if MineralBuyer and Player.Character and HRP then
            local originalPos = HRP.CFrame
            local BuyerPart = MineralBuyer:FindFirstChild("HumanoidRootPart") or 
                             MineralBuyer:FindFirstChild("Head") or 
                             MineralBuyer:FindFirstChildWhichIsA("Part")
            
            if BuyerPart then
                HRP.CFrame = BuyerPart.CFrame + Vector3.new(0, 3, 0)
                task.wait(0.3)
                
                for _, obj in pairs(MineralBuyer:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") then
                        fireproximityprompt(obj)
                    end
                    if obj:IsA("ClickDetector") then
                        fireclickdetector(obj)
                    end
                end
                
                task.wait(0.5)
                HRP.CFrame = originalPos
                
                Rayfield:Notify({
                    Title = "Venta Completada",
                    Content = "Minerales vendidos!",
                    Duration = 2
                })
            else
                Rayfield:Notify({
                    Title = "Error",
                    Content = "No se encontró el punto de venta.",
                    Duration = 3,
                    Image = "alert"
                })
            end
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "No se encontró 'Mineral Buyer' en el mapa.",
                Duration = 3,
                Image = "alert"
            })
        end
    end,
})

-- ═══════════════════════════════════════════════════
-- PESTAÑA: MINERÍA (Super Pickaxe)
-- ═══════════════════════════════════════════════════
local MiningTab = Window:CreateTab("⛏️ Minería", "pickaxe")

MiningTab:CreateSection("Mejoras de Herramientas")

-- SUPER PICKAXE TOGGLE
local SuperPickaxeToggle = MiningTab:CreateToggle({
    Name = "⚡ Super Pickaxe (Daño x10)",
    CurrentValue = false,
    Flag = "SuperPickaxe",
    Callback = function(Value)
        SuperPickaxeEnabled = Value
        
        if SuperPickaxeEnabled then
            Rayfield:Notify({
                Title = "Super Pickaxe Activado",
                Content = "Daño aumentado a rocas! Golpea más fuerte y rápido.",
                Duration = 3
            })
            
            -- Loop para mejorar el daño de la pickaxe
            task.spawn(function()
                while SuperPickaxeEnabled do
                    local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
                    if tool and tool.Name:lower():find("pick") then
                        -- Activar herramienta constantemente para daño rápido
                        if tool:FindFirstChild("Activate") then
                            tool:Activate()
                        end
                        
                        -- Buscar rocas cercanas y golpearlas
                        local RocksFolder = workspace:FindFirstChild("Prisones") and 
                                          workspace.Prisones:FindFirstChild("Rocks")
                        
                        if RocksFolder and HRP then
                            for _, rock in pairs(RocksFolder:GetChildren()) do
                                if rock.Name == "Part" and rock:IsA("BasePart") then
                                    local distance = (rock.Position - HRP.Position).Magnitude
                                    if distance < 15 then
                                        -- Simular golpe en la roca
                                        for i = 1, 5 do -- 5 golpes por ciclo
                                            if firetouchinterest then
                                                firetouchinterest(HRP, rock, 0)
                                                firetouchinterest(HRP, rock, 1)
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        else
            Rayfield:Notify({
                Title = "Super Pickaxe Desactivado",
                Content = "Modo normal restaurado.",
                Duration = 2
            })
        end
    end,
})

-- BOTÓN PARA CONSEGUIR PICKAXE
MiningTab:CreateButton({
    Name = "🎒 Equipar Pickaxe",
    Callback = function()
        local Backpack = Player:WaitForChild("Backpack")
        local Pickaxe = Backpack:FindFirstChild("Pickaxe") or 
                       (Player.Character and Player.Character:FindFirstChild("Pickaxe"))
        
