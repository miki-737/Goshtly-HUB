    Gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color or CONFIG.COLORS.ACCENT),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(200, 100, 255)),
        ColorSequenceKeypoint.new(1, color or CONFIG.COLORS.ACCENT)
    })
    Gradient.Rotation = 45
    Gradient.Parent = ActionFrame
    
