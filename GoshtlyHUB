-- Variables de control
local AutoMineRunning = false
local AutoSellRunning = false
local DamageModEnabled = false

-- Función para encontrar ores cercanos
local function FindNearestOre()
    local nearest = nil
    local minDistance = math.huge
    
    local oreNames = {"Ore", "Rock", "Stone", "Azurith", "RawIron", "Coal", "RawCopper", "RawGold", 
                    "Iron", "Copper", "Gold", "Cobblestone", "Mineral"}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then
            local nameLower = obj.Name:lower()
            for _, oreName in ipairs(oreNames) do
                if nameLower:find(oreName:lower()) then
                    local distance = (obj.Position - HumanoidRootPart.Position).magnitude
                    if distance < minDistance and distance < 100 then
                        minDistance = distance
                        nearest = obj
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Función para picar
local function MineOre(ore)
    if not ore then return end
    
    -- Teletransportar
    HumanoidRootPart.CFrame = ore.CFrame * Config.TeleportOffset
    
    -- Activar herramienta de picar si existe
    local tool = Character:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
    else
        -- Simular clic si no hay herramienta
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end
    
    -- Fire remote events comunes de minado
    local args = {
        [1] = ore,
        [2] = Config.DamageModifier and Config.DamageAmount or 1
    }
    
    -- Intentar diferentes remotos comunes
    pcall(function()
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("MineOre"):FireServer(unpack(args))
    end)
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Mine"):FireServer(ore)
    end)
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("Mine"):FireServer(ore)
    end)
    
    -- Efecto visual
    local beam = Instance.new("Part")
    beam.Size = Vector3.new(0.2, 0.2, (ore.Position - HumanoidRootPart.Position).magnitude)
    beam.CFrame = CFrame.lookAt(HumanoidRootPart.Position, ore.Position) * CFrame.new(0, 0, -beam.Size.Z/2)
    beam.Anchored = true
    beam.CanCollide = false
    beam.Color = Colors.Accent
    beam.Material = Enum.Material.Neon
    beam.Parent = workspace
    
    game:GetService("Debris"):AddItem(beam, 0.1)
end

-- Auto Mine Loop
local MineConnection = nil
function StartAutoMine()
    if AutoMineRunning then return end
    AutoMineRunning = true
    
    MineConnection = RunService.Heartbeat:Connect(function()
        if not AutoMineRunning then return end
        
        local ore = FindNearestOre()
        if ore then
            MineOre(ore)
        end
        
        task.wait(Config.MineDelay)
    end)
end

function StopAutoMine()
    AutoMineRunning = false
    if MineConnection then
        MineConnection:Disconnect()
        MineConnection = nil
    end
end

function TeleportToNearestOre()
    local ore = FindNearestOre()
    if ore then
        HumanoidRootPart.CFrame = ore.CFrame * Config.TeleportOffset
        
        -- Efecto de partículas
        for i = 1, 10 do
            local particle = Instance.new("Part")
            particle.Shape = Enum.PartType.Ball
            particle.Size = Vector3.new(0.5, 0.5, 0.5)
            particle.Position = HumanoidRootPart.Position + Vector3.new(math.random(-5,5), math.random(-5,5), math.random(-5,5))
            particle.Color = Colors.Accent
            particle.Material = Enum.Material.Neon
            particle.Anchored = false
            particle.Parent = workspace
            game:GetService("Debris"):AddItem(particle, 1)
        end
    end
end

-- Auto Sell
local SellConnection = nil
function StartAutoSell()
    if AutoSellRunning then return end
    AutoSellRunning = true
    
    SellConnection = RunService.Heartbeat:Connect(function()
        if not AutoSellRunning then return end
        
        SellAllMaterials()
        task.wait(Config.SellDelay)
    end)
end

function StopAutoSell()
    AutoSellRunning = false
    if SellConnection then
        SellConnection:Disconnect()
        SellConnection = nil
    end
end

function SellAllMaterials()
    -- Intentar diferentes métodos de venta comunes
    pcall(function()
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SellAll"):FireServer()
    end)
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Sell"):FireServer()
    end)
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("Sell"):FireServer()
    end)
    
    -- Intentar vender items específicos
    local materials = {"Azurith", "RawIron", "Coal", "RawCopper", "RawGold", 
                     "Iron", "Copper", "Gold", "Stone", "Ore"}
    
    for _, material in ipairs(materials) do
        pcall(function()
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SellItem"):FireServer(material)
        end)
    end
end

-- Damage Modifier
function EnableDamageModifier()
    DamageModEnabled = true
    
    -- Hook a herramientas
    Character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and DamageModEnabled then
            local tool = child
            task.wait(0.1)
            
            -- Modificar daño si existe
            if tool:FindFirstChild("Damage") then
                tool.Damage.Value = Config.DamageAmount
            end
            
            -- Conectar al activar
            tool.Activated:Connect(function()
                if DamageModEnabled then
                    -- Fire con daño modificado
                    pcall(function()
                        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("DealDamage"):FireServer(Config.DamageAmount)
                    end)
                end
            end)
        end
    end)
end

function DisableDamageModifier()
    DamageModEnabled = false
end

